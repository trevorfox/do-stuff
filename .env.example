# Required
CURSOR_API_KEY=replace-with-your-cursor-api-key

# Optional API auth settings
CURSOR_API_AUTH_MODE=basic
CURSOR_API_BASE_URL=https://api.cursor.com
CURSOR_API_REQUEST_TIMEOUT_SECONDS=60

# Optional defaults for launch/run-scenario commands
CURSOR_REPOSITORY=https://github.com/your-org/your-repo
CURSOR_SOURCE_REF=main
CURSOR_REMOTE_NAME=origin
CURSOR_MODEL=claude-4-sonnet-thinking

# Optional polling defaults for run-scenario
CURSOR_API_POLL_INTERVAL_SECONDS=15
CURSOR_API_WAIT_TIMEOUT_SECONDS=1800
